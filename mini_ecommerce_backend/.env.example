# =============================================================================
# DEVELOPMENT  ← active now
# Comment out this entire section when switching to staging
# =============================================================================

SECRET_KEY=your-dev-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_NAME=ecommerce_db
DB_USER=postgres
DB_PASSWORD=your-local-db-password
DB_HOST=localhost
DB_PORT=5432

FRONTEND_URL=http://localhost:5173

# Gmail SMTP — used locally when MAILJET_* keys are blank
# EMAIL_HOST_PASSWORD must be a Gmail App Password (not your regular password).
# Generate: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ShurjoPay sandbox (public test credentials — safe to use locally)
SHURJOPAY_BASE_URL=https://sandbox.shurjopayment.com
SHURJOPAY_USERNAME=sp_sandbox
SHURJOPAY_PASSWORD=pyyk97hu&6u6
SHURJOPAY_PREFIX=SP
SHURJOPAY_RETURN_URL=http://localhost:8000/api/payments/callback/
SHURJOPAY_CANCEL_URL=http://localhost:8000/api/payments/callback/

RETURN_WINDOW_DAYS=7
CRON_SECRET=

# Unsplash — used by the fetch_product_images management command
# Get a free key: https://unsplash.com/developers → New Application → Demo
UNSPLASH_ACCESS_KEY=


# =============================================================================
# STAGING  ← commented out
# Uncomment this entire section and comment out the dev section above when
# running locally against the staging (Neon) database
# =============================================================================

# DJANGO_SETTINGS_MODULE=ecommerce_backend.settings.staging
# SECRET_KEY=your-staging-secret-key-here
# DEBUG=False
# ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=https://your-app.netlify.app

# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# FRONTEND_URL=https://your-app.netlify.app

# Mailjet — HTTP API (Render free tier blocks outbound SMTP)
# Get keys: https://app.mailjet.com → Account → API Keys
# MAILJET_API_KEY=your-mailjet-api-key
# MAILJET_SECRET_KEY=your-mailjet-secret-key
# MAILJET_FROM_EMAIL=your-verified-sender@example.com

# Cloudinary — required in staging (Render disk is ephemeral)
# Get values: https://cloudinary.com → Dashboard
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ShurjoPay — same sandbox credentials; only return/cancel URLs change
# SHURJOPAY_BASE_URL=https://sandbox.shurjopayment.com
# SHURJOPAY_USERNAME=sp_sandbox
# SHURJOPAY_PASSWORD=pyyk97hu&6u6
# SHURJOPAY_PREFIX=SP
# SHURJOPAY_RETURN_URL=https://your-app.onrender.com/api/payments/callback/
# SHURJOPAY_CANCEL_URL=https://your-app.onrender.com/api/payments/callback/

# RETURN_WINDOW_DAYS=7
# CRON_SECRET=your-cron-secret-here

# UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# SUPERUSER_EMAIL=your@email.com
# SUPERUSER_PASSWORD=your-strong-password
